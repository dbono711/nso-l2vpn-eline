<config-template xmlns="http://tail-f.com/ns/config/1.0">
	<devices xmlns="http://tail-f.com/ns/ncs">
		<device>
			<name>{$DEVICE-NAME}</name>
			<config>

				<!-- policy map -->
				<policy-map xmlns="urn:ios">
					<name>{$SERVICE-ID}</name>
					<class-default>
						<class>
							<name>class-default</name>
							<police-policy-map>
								<police>
									<cir>{$CIR}</cir>
									<actions>
										<conform-transmit>
											<conform-action>
												<transmit/>
											</conform-action>
										</conform-transmit>
										<exceed-drop>
											<exceed-action>
												<drop/>
											</exceed-action>
										</exceed-drop>
									</actions>
								</police>
							</police-policy-map>
						</class>
					</class-default>
				</policy-map>

				<!-- interfaces -->
				<interface xmlns="urn:ios">

				    <!-- pseudowire interface -->
				    <pseudowire>
						<name>{$VPN-ID}</name>
						<encapsulation>mpls</encapsulation>
						<neighbor>
						    <address>{$PEER}</address>
							<vcid>{$VPN-ID}</vcid>
						</neighbor>
					</pseudowire>

				    <!-- Ethernet interfaces in port mode -->
					<Ethernet when="{$INTERFACE-TYPE = 'Ethernet' and $PORT-MODE = 'true'}">
						<name>{$INTERFACE-ID}</name>
						<mtu>{$MTU}</mtu>
						<service-policy>
							<input>{$SERVICE-ID}</input>
						</service-policy>
					</Ethernet>

					<!-- Ethernet interfaces in VLAN mode -->
					<Ethernet when="{$INTERFACE-TYPE = 'Ethernet' and $PORT-MODE = 'false'}">
						<name>{$INTERFACE-ID}.{/provider-edge/device[name=$DEVICE-NAME]/interface[name=$INTERFACE-NAME]/efp-id}</name>
						<encapsulation>
                            <dot1Q>
                                <vlan-id>{$VLAN-ID}</vlan-id>
                            </dot1Q>
                        </encapsulation>
                        <mtu>{$MTU}</mtu>
                        <service-policy>
                            <input>{$SERVICE-ID}</input>
                        </service-policy>
					</Ethernet>

					<!-- Gigabit Ethernet interfaces in port mode -->
              		<GigabitEthernet when="{$INTERFACE-TYPE = 'GigabitEthernet' and $PORT-MODE = 'true'}">
                        <name>{$INTERFACE-ID}</name>
                        <mtu>{$MTU}</mtu>
                        <service-policy>
                            <input>{$SERVICE-ID}</input>
                        </service-policy>
                    </GigabitEthernet>

              		<!-- Gigabit Ethernet interfaces in VLAN mode -->
              		<GigabitEthernet when="{$INTERFACE-TYPE = 'GigabitEthernet' and $PORT-MODE = 'false'}">
                        <name>{$INTERFACE-ID}.{/provider-edge/device[name=$DEVICE-NAME]/interface[name=$INTERFACE-NAME]/efp-id}</name>
                        <encapsulation>
                            <dot1Q>
                                <vlan-id>{$VLAN-ID}</vlan-id>
                            </dot1Q>
                        </encapsulation>
                        <mtu>{$MTU}</mtu>
                        <service-policy>
                            <input>{$SERVICE-ID}</input>
                        </service-policy>
                    </GigabitEthernet>

                    <!-- TenGigabitEthernet interfaces in port mode -->
              		<TenGigabitEthernet when="{$INTERFACE-TYPE = 'TenGigabitEthernet' and $PORT-MODE = 'true'}">
                        <name>{$INTERFACE-ID}</name>
                        <mtu>{$MTU}</mtu>
                        <service-policy>
                            <input>{$SERVICE-ID}</input>
                        </service-policy>
                    </TenGigabitEthernet>

              		<!-- TenGigabitEthernet interfaces in VLAN mode -->
              		<TenGigabitEthernet when="{$INTERFACE-TYPE = 'TenGigabitEthernet' and $PORT-MODE = 'false'}">
                        <name>{$INTERFACE-ID}.{/provider-edge/device[name=$DEVICE-NAME]/interface[name=$INTERFACE-NAME]/efp-id}</name>
                        <encapsulation>
                            <dot1Q>
                                <vlan-id>{$VLAN-ID}</vlan-id>
                            </dot1Q>
                        </encapsulation>
                        <mtu>{$MTU}</mtu>
                        <service-policy>
                            <input>{$SERVICE-ID}</input>
                        </service-policy>
                    </TenGigabitEthernet>
				</interface>

				<!-- l2vpn xconnect context -->
				<l2vpn-xconnect xmlns="urn:ios">
				    <l2vpn>
						<xconnect>
						    <context>
								<name>{$SERVICE-ID}</name>
								<member>
				                    <interface-list>
										<name>pseudowire{$VPN-ID}</name>
									</interface-list>
								    <interface-list when="{$PORT-MODE = 'true'}">
										<name>{$INTERFACE-TYPE}{$INTERFACE-ID}</name>
									</interface-list>
									<interface-list when="{$PORT-MODE = 'false'}">
									    <name>{$INTERFACE-TYPE}{$INTERFACE-ID}.{/provider-edge/device[name=$DEVICE-NAME]/interface[name=$INTERFACE-NAME]/efp-id}</name>
									</interface-list>
								</member>
							</context>
						</xconnect>
					</l2vpn>
				</l2vpn-xconnect>

			</config>
		</device>
	</devices>
</config-template>
